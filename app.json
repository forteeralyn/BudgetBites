        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.eralyn.forte.BudgetBites"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "1d93e940-8b99-4a26-bef4-fab393ba4a97"
      }
    },
    "plugins": [
      "expo-font"
    ]
  }
}
